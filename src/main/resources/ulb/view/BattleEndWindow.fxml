<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" alignment="CENTER"
      spacing="20.0" fx:controller="ulb.view.BattleEndWindow">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Label fx:id="messageLabel" style="-fx-font-size: 14px;"/>
    <Button onAction="#handleReturn" prefHeight="50" prefWidth="200" text="Return to Main Menu" />

</VBox>
