<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" alignment="CENTER"
      spacing="20.0" fx:controller="ulb.view.windows.BattleModeWindow">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="10.0">
        <Label text="Votre Équipe:" style="-fx-font-size: 20px;"/>
        <GridPane fx:id="playerTeamGrid" hgap="10" vgap="10" alignment="CENTER"/>
    </VBox>

    <Button text="Automatic Battle" onAction="#handleAutomaticBattle" prefWidth="200" prefHeight="50"/>
    <Button text="Controlled Battle" onAction="#handleControlledBattle" prefWidth="200" prefHeight="50"/>
    <Button text="Tower Mode" onAction="#handleTowerBattle" prefWidth="200" prefHeight="50"/>

</VBox>
