<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane style="-fx-background-image: url(backgrounds/BattleModeBackground.png); -fx-background-size: stretch"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="ulb.view.windows.BattleModeWindow">

    <VBox fx:id="content"
          alignment="CENTER"
          spacing="20.0"
          maxWidth="800"
          maxHeight="600">

        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>

        <VBox alignment="CENTER" spacing="10.0">
            <Label text="Votre Équipe:" style="-fx-font-size: 20px;"/>
            <GridPane fx:id="playerTeamGrid" hgap="10" vgap="10" alignment="CENTER"/>
        </VBox>

        <Button style="-fx-background-color: #38466f"
                text="Bataille Classique" onAction="#handleControlledBattle" prefWidth="200" prefHeight="50"/>
        <Button style="-fx-background-color: #13550d"
                text="Bataille Automatique" onAction="#handleAutomaticBattle" prefWidth="200" prefHeight="50"/>

    </VBox>
</StackPane>