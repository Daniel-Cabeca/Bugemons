<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-image: url(backgrounds/BattleModeBackground.png); -fx-background-size: stretch" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.view.windows.BattleModeWindow">

    <VBox fx:id="content" alignment="CENTER" maxHeight="600" maxWidth="800" spacing="20.0">

        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <VBox alignment="CENTER" spacing="10.0">
            <Label style="-fx-font-size: 20px;" text="Votre Équipe:" />
            <GridPane fx:id="playerTeamGrid" alignment="CENTER" hgap="10" vgap="10" />
        </VBox>
      <VBox alignment="CENTER" spacing="20">
         <children>
            <HBox alignment="CENTER" spacing="20">
               <children>
                  <Button onAction="#handleControlledBattle" prefHeight="50.0" prefWidth="200.0" style="-fx-background-color: #8D89BA" text="Combat Classique" />
                  <Button onAction="#handleAutomaticBattle" prefHeight="50" prefWidth="200" style="-fx-background-color: #97B35F" text="Combat Automatique" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="20">
               <children>
                  <Button alignment="CENTER" onAction="#handleNewTowerBattle" prefHeight="50" prefWidth="200" style="-fx-background-color: #9B3E62" text="Nouvelle Tour NO" />
                  <Button alignment="CENTER" onAction="#handleContinueTowerBattle" prefHeight="50" prefWidth="200" style="-fx-background-color: #EB9D52;" text="Continuer Tour NO" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Button onAction="#handleReturn" prefHeight="50" prefWidth="200" style="-fx-background-color: #777777;" text="Retour" />

    </VBox>
</StackPane>
