<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ulb.view.windows.BattleWindow"
      spacing="10" alignment="TOP_CENTER">

    <padding>
        <Insets top="15" right="20" bottom="15" left="20"/>
    </padding>

    <!-- ── BATTLE FIELD ── -->
    <HBox alignment="TOP_CENTER" spacing="40">

        <!-- Left column: opponent stat-box (top), player stat-box + sprite (bottom) -->
        <VBox alignment="TOP_LEFT" spacing="50" HBox.hgrow="ALWAYS">

            <!-- Opponent stat box -->
            <VBox styleClass="stat-box" maxWidth="250" spacing="5" style="-fx-background-color: #f0ead0; -fx-background-radius: 10; -fx-border-color: #7a6340; -fx-border-width: 2; -fx-border-radius: 10; -fx-padding: 8 14 8 14; -fx-effect: dropshadow(three-pass-box, #00000055, 6, 0, 2, 2);">
                <Label fx:id="OpponentBugemonLabel" styleClass="bugemon-name"/>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="HP" styleClass="hp-label"/>
                    <ProgressBar fx:id="OppentHPBar" maxWidth="Infinity" maxHeight="14" HBox.hgrow="ALWAYS"/>
                </HBox>
                <Label fx:id="OpponentHPNumber" styleClass="hp-number" maxWidth="Infinity"/>
            </VBox>

            <!-- Player section: stat-box above sprite -->
            <VBox spacing="4" alignment="BOTTOM_LEFT">
                <VBox styleClass="stat-box" maxWidth="250" spacing="5" style="-fx-background-color: #f0ead0; -fx-background-radius: 10; -fx-border-color: #7a6340; -fx-border-width: 2; -fx-border-radius: 10; -fx-padding: 8 14 8 14; -fx-effect: dropshadow(three-pass-box, #00000055, 6, 0, 2, 2);">
                    <Label fx:id="PlayerBugemonLabel" styleClass="bugemon-name"/>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="HP" styleClass="hp-label"/>
                        <ProgressBar fx:id="PlayerBugemonHPBar" maxWidth="Infinity" maxHeight="14" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="PlayerBugemonHPNumber" styleClass="hp-number" maxWidth="Infinity"/>
                </VBox>
                <ImageView fx:id="PlayerBugemon" fitWidth="150" fitHeight="150" preserveRatio="true"/>
            </VBox>

        </VBox>

        <!-- Right column: opponent sprite -->
        <VBox alignment="TOP_RIGHT" HBox.hgrow="ALWAYS">
            <ImageView fx:id="OpponentBugemon" fitWidth="150" fitHeight="150" preserveRatio="true"/>
        </VBox>

    </HBox>

    <!-- ── TEAM OVERVIEW ── -->
    <HBox alignment="CENTER" spacing="20">
        <VBox alignment="CENTER" spacing="4">
            <Label text="Votre Équipe" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <GridPane fx:id="playerTeamGrid" hgap="6" vgap="6" alignment="CENTER"/>
        </VBox>
        <Separator orientation="VERTICAL"/>
        <VBox alignment="CENTER" spacing="4">
            <Label text="Équipe Adverse" style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
            <GridPane fx:id="opponentTeamGrid" hgap="6" vgap="6" alignment="CENTER"/>
        </VBox>
    </HBox>

    <!-- ── BATTLE LOG ── -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label fx:id="battleLog" wrapText="true" minHeight="50" HBox.hgrow="ALWAYS"
               style="-fx-background-color: white; -fx-border-color: #999; -fx-border-radius: 4;
                      -fx-background-radius: 4; -fx-padding: 6; -fx-font-size: 14px;"/>
        <Button fx:id="nextMessageButton" text="Suite" prefWidth="70" prefHeight="50"/>
    </HBox>

    <!-- ── ACTION AREA ── -->

    <!-- Main action buttons (visible by default) -->
    <GridPane fx:id="buttonsGrid" hgap="10" vgap="10" alignment="CENTER">
        <Button fx:id="attackButton" text="Attaque" onAction="#handleAttack"
                prefWidth="130" prefHeight="40"
                GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button fx:id="itemButton" text="Objet" onAction="#handleItemMenu"
                prefWidth="130" prefHeight="40"
                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button fx:id="switchButton" text="Changer" onAction="#handleBugemonsMenu"
                prefWidth="130" prefHeight="40"
                GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button fx:id="runButton" text="Fuir"
                prefWidth="130" prefHeight="40"
                GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button fx:id="autoButton" text="Auto" onAction="#handleAuto"
                prefWidth="130" prefHeight="40"
                GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Button fx:id="backButton" text="Menu Principal" onAction="#handleReturn"
                prefWidth="130" prefHeight="40"
                GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <!-- Inventory view (hidden by default) -->
    <VBox fx:id="inventoryView" visible="false" managed="false" spacing="8" alignment="CENTER">
        <ListView fx:id="inventoryList" prefWidth="420" prefHeight="180"/>
        <Button fx:id="backToMenuButton" text="Retour" onAction="#handleBackToMenu" prefWidth="200"/>
    </VBox>

    <!-- Bugemons view (hidden by default) -->
    <VBox fx:id="bugemonsView" visible="false" managed="false" spacing="8" alignment="CENTER">
        <ListView fx:id="bugemonsList" prefWidth="420" prefHeight="180"/>
        <Button text="Retour" onAction="#handleBackToMenu" prefWidth="200"/>
    </VBox>

    <!-- Abilities view (hidden by default) -->
    <VBox fx:id="abilitiesView" visible="false" managed="false" spacing="8" alignment="CENTER">
        <ListView fx:id="abilitiesList" prefWidth="420" prefHeight="180"/>
        <Button text="Retour" onAction="#handleBackToMenu" prefWidth="200"/>
    </VBox>

</VBox>
