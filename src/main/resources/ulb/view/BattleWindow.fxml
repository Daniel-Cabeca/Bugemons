<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" alignment="CENTER"
	spacing = "20.0" fx:controller="ulb.view.windows.BattleWindow">

	<padding>
		<Insets top="20" right="20" bottom="20" left="20"/>
	</padding>

	<HBox alignment="CENTER" spacing="20.0">

	<VBox alignment="CENTER" spacing="10.0">
		<Label text="Votre Équipe:" style="-fx-font-size: 20px;"/>
		<GridPane fx:id="playerTeamGrid" hgap="10" vgap="10" alignment="CENTER"/>
	</VBox>

	<Separator orientation="VERTICAL"/>

	<VBox alignment="CENTER" spacing="10.0">
		<Label text="Équipe Adverse:" style="-fx-font-size: 20px;"/>
		<GridPane fx:id="opponentTeamGrid" hgap="10" vgap="10" alignment="CENTER"/>
	</VBox>

	</HBox>

	<HBox alignment="CENTER" spacing="20.0">
		<VBox alignment="CENTER" spacing="10.0">
			<Label text="Inventaire" style="-fx-font-size: 20px;"/>
			<ListView fx:id="inventoryList" prefWidth="400" prefHeight="200"/>
		</VBox>
	</HBox>

    <Button text="Menu Principal" onAction="#handleReturn" prefWidth="200" prefHeight="50"/>

</VBox>
