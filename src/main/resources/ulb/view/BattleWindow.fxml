<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>

<GridPane style= "-fx-background-image: url(backgrounds/BattleBackground.png); -fx-background-size: stretch"
          alignment="BOTTOM_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.view.windows.BattleWindow">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="300.0" />
        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="300.0" />
        <ColumnConstraints hgrow="ALWAYS" minWidth="347.0" prefWidth="390.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="150.0" prefHeight="220.0" valignment="CENTER" vgrow="SOMETIMES" />
        <RowConstraints minHeight="50.0"  prefHeight="80.0"  vgrow="NEVER" />
        <RowConstraints minHeight="150.0" prefHeight="220.0" vgrow="SOMETIMES" />
    </rowConstraints>
    <children>
        <VBox spacing="5.0"
              GridPane.columnIndex="0"
              GridPane.rowIndex="0"
              GridPane.valignment="TOP"
              GridPane.halignment="LEFT">
            <padding>
                <javafx.geometry.Insets top="10" left="10"/>
            </padding>
            <children>
                <Button text="👥" onAction="#openSocialPanel"/>
                <Label fx:id="floorLabel" style="-fx-font-size: 30px"/>
                <Label fx:id="roomLabel" style="-fx-font-size: 30px"/>
            </children>
        </VBox>
        <ImageView fx:id="OpponentBugemon" fitHeight="300.0" fitWidth="300.0" preserveRatio="true" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.valignment="CENTER" translateX="-40">
            <image>
                <Image url="@../../png/commitide.png" />
            </image>
        </ImageView>
        <ImageView fx:id="PlayerBugemon" fitHeight="358.0" fitWidth="358.0" nodeOrientation="RIGHT_TO_LEFT" preserveRatio="true" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" translateY="-60" translateX="20">
            <image>
                <Image url="@../../png/lichenox.png" />
            </image>
        </ImageView>
        <VBox styleClass="stat-box" GridPane.columnIndex="1" GridPane.rowIndex="2"
              GridPane.halignment="LEFT" GridPane.valignment="CENTER"
              GridPane.vgrow="NEVER" GridPane.fillHeight="false"
              prefWidth="600" maxWidth="600" spacing="11"
              style="-fx-padding: 17 30 17 30;"
              translateY="-120" translateX="600">
            <HBox alignment="CENTER_LEFT" maxWidth="Infinity">
                <Label fx:id="PlayerBugemonLabel" styleClass="bugemon-name"/>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="PlayerLevelLabel" styleClass="bugemon-level"/>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="13">
                <Label text="HP" styleClass="hp-label"/>
                <ProgressBar fx:id="PlayerBugemonHPBar" prefWidth="468" maxWidth="468" maxHeight="24" progress="1.0"/>
            </HBox>
            <Label fx:id="PlayerBugemonHPNumber" styleClass="hp-number" maxWidth="Infinity"/>
        </VBox>

        <VBox styleClass="stat-box" GridPane.columnIndex="1" GridPane.rowIndex="0"
              GridPane.halignment="RIGHT" GridPane.valignment="CENTER"
              GridPane.vgrow="NEVER" GridPane.fillHeight="false"
              prefWidth="600" maxWidth="600" spacing="11"
              style="-fx-padding: 17 30 17 30;"
              translateX="-560">
            <HBox alignment="CENTER_LEFT" maxWidth="Infinity">
                <Label fx:id="OpponentBugemonLabel" styleClass="bugemon-name"/>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="OpponentLevelLabel" styleClass="bugemon-level"/>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="13">
                <Label text="HP" styleClass="hp-label"/>
                <ProgressBar fx:id="OpponentHPBar" prefWidth="468" maxWidth="468" maxHeight="24" progress="1.0"/>
            </HBox>
            <Label fx:id="OpponentHPNumber" styleClass="hp-number" maxWidth="Infinity"/>
        </VBox>
        <VBox fx:id="messageBox" styleClass="battle-message-box"
              visible="false" managed="false"
              prefHeight="250.0" maxHeight="250.0" maxWidth="Infinity"
              GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="2"
              GridPane.halignment="CENTER" GridPane.valignment="BOTTOM"
              GridPane.fillHeight="true">
            <Label fx:id="battleLog" wrapText="true" maxWidth="Infinity" VBox.vgrow="ALWAYS"/>
        </VBox>
        <GridPane fx:id="buttonsGrid" styleClass="battle-menu" alignment="CENTER" prefHeight="250.0" maxHeight="250.0" maxWidth="Infinity" scaleX="1.3" translateX="-40" nodeOrientation="LEFT_TO_RIGHT" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="BOTTOM" GridPane.fillHeight="false">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="40.0" prefHeight="40.0" vgrow="NEVER" />
                <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="NEVER" />
                <RowConstraints minHeight="3.0" prefHeight="3.0" vgrow="NEVER" />
                <RowConstraints minHeight="50.0" prefHeight="50.0" vgrow="NEVER" />
            </rowConstraints>
            <children>
                <Button fx:id="autoButton" maxWidth="Infinity" mnemonicParsing="false" text="Auto" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan= "2" GridPane.halignment="CENTER" prefHeight="40" GridPane.hgrow="ALWAYS" onAction="#handleAuto"/>
                <Button fx:id="attackButton" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" text="Attaquer" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS" onAction="#handleAttack"/>
                <Button fx:id="itemButton" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" text="Objet" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS" onAction="#handleItemMenu"/>
                <Separator GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="2" style="-fx-background-color: #888888; -fx-padding: 0;"/>
                <Button fx:id="switchButton" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" text="Échanger" GridPane.columnIndex="0" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="3" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS" onAction="#handleBugemonsMenu"/>
                <Button fx:id="runButton" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" text="Fuir" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="3" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS" onAction="#handleReturn"/>
            </children>
        </GridPane>
        <VBox fx:id="inventoryView" visible="false" managed="false" spacing="10.0" prefHeight="250.0" maxHeight="250.0" maxWidth="Infinity" scaleX="1.3" translateX="-40" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="BOTTOM" GridPane.fillHeight="false">
            <children>
                <ListView fx:id="inventoryList" prefHeight="195.0" maxWidth="Infinity" VBox.vgrow="ALWAYS"/>
                <Button fx:id="backToMenuButton" text="Retour" onAction="#handleBackToMenu" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="NEVER"/>
            </children>
        </VBox>
        <VBox fx:id="bugemonsView" visible="false" managed="false" spacing="10.0" prefHeight="250.0" maxHeight="250.0" maxWidth="Infinity" scaleX="1.3" translateX="-40" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="BOTTOM" GridPane.fillHeight="false">
            <children>
                <ListView fx:id="bugemonsList" prefHeight="195.0" maxWidth="Infinity" VBox.vgrow="ALWAYS"/>
                <Button text="Retour" onAction="#handleBackToMenu" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="NEVER"/>
            </children>
        </VBox>
        <VBox fx:id="abilitiesView" visible="false" managed="false" spacing="10.0" prefHeight="250.0" maxHeight="250.0" maxWidth="Infinity" scaleX="1.3" translateX="-40" GridPane.columnIndex="2" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="BOTTOM" GridPane.fillHeight="false">
            <children>
                <ListView fx:id="abilitiesList" prefHeight="195.0" maxWidth="Infinity" VBox.vgrow="ALWAYS"/>
                <Button text="Retour" onAction="#handleBackToMenu" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="NEVER"/>
            </children>
        </VBox>
    </children>
</GridPane>
