<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER"
      spacing = "20.0"
      fx:controller="ulb.view.CreateTeamMenu">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>


    <Label text="Your team:" style="-fx-font-size: 20px;"/>

    <GridPane fx:id="selectedBugemons" hgap="10" vgap="10" alignment="CENTER"/>

    <Separator/>

    <Label text="Available Bugemons:" style="-fx-font-size: 20px;"/>

    <GridPane fx:id="availableBugemons" hgap="10" vgap="10" alignment="CENTER"/>

    <Button text="Confirm Team" onAction="#handleConfirmTeam" prefWidth="200" prefHeight="50"/>
    <Button text="Return to Main Menu" onAction="#handleReturn" prefWidth="200" prefHeight="50"/>

</VBox>
