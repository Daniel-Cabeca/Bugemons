<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600" prefWidth="900"
            style="-fx-background-color: rgba(30, 35, 45, 0.65);
                   -fx-background-radius: 12;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ulb.view.windows.FriendsOverlay">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="-fx-padding: 10;
                     -fx-background-color: rgba(200, 205, 215, 0.85);
                     -fx-background-radius: 12 12 0 0;">

            <Label text="Chat"
                   style="-fx-text-fill: black;
                          -fx-font-size: 16px;
                          -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS" />

            <Button text="X" onAction="#handleClose"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: black;
                           -fx-font-size: 14px;
                           -fx-font-weight: bold;" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260"
              spacing="10"
              style="-fx-padding: 10;
                     -fx-background-color: rgba(156, 188, 225, 0.75);">

            <Label text="Friends"
                   style="-fx-text-fill: black;
                          -fx-font-size: 14px;
                          -fx-font-weight: bold;" />

            <ListView fx:id="friendsList"
                      style="-fx-background-color: rgba(233, 237, 242, 0.85);
                             -fx-control-inner-background: rgba(233, 237, 242, 0.85);" />
        </VBox>
    </left>

    <center>
        <VBox spacing="10"
              style="-fx-padding: 10;
                     -fx-background-color: rgba(233, 237, 242, 0.75);">

            <ListView fx:id="chatList"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent;
                             -fx-control-inner-background: transparent;" />

            <HBox spacing="10">

                <TextField fx:id="messageField"
                           promptText="..."
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: rgba(255,255,255,0.9);
                                  -fx-text-fill: black;
                                  -fx-prompt-text-fill: gray;
                                  -fx-background-radius: 6;" />

                <Button text="Send" onAction="#handleSend"
                        prefWidth="80"
                        style="-fx-background-color: #5b8cff;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 6;" />
            </HBox>

        </VBox>
    </center>

</BorderPane>