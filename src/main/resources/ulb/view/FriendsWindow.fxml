<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.view.windows.FriendsWindow">
   <children>
      <Label fx:id="windowLabel" style="-fx-font-size: 24;" text="Amis/Classement" />
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <TextField fx:id="usernameField" />
            <Button mnemonicParsing="false" onAction="#inviteFriend" text="Inviter" />
         </children>
      </HBox>
      <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="ALWAYS" vbarPolicy="ALWAYS">
         <content>
            <VBox fx:id="friendsList" alignment="TOP_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
            </VBox>
         </content>
      </ScrollPane>
      <Button mnemonicParsing="false" onAction="#returnToMultiplayerWindow" text="Retour" />
   </children>
</VBox>
