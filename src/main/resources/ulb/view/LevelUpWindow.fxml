<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.LevelUpController"
           prefHeight="450.0" prefWidth="750.0"
           style="-fx-background-color: white;">

    <VBox alignment="CENTER" spacing="40">

        <Label text="LEVEL UP!"
               style="-fx-text-fill:#1e3a8a; -fx-font-size:40px; -fx-font-weight:bold;" />
        <Label text="Choisis ton bonus"
               style="-fx-text-fill:#444; -fx-font-size:18px;" />
        <HBox alignment="CENTER" spacing="35">

            <VBox alignment="CENTER" spacing="25"
                  prefWidth="180"
                  style="-fx-background-color:#f5f7ff;
                         -fx-background-radius:15;
                         -fx-padding:30;
                         -fx-border-color:#3b82f6;
                         -fx-border-radius:15;
                         -fx-border-width:2;">
                <Label fx:id="choice1Label"
                       wrapText="true"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       style="-fx-text-fill:#111; -fx-font-size:18px; -fx-font-weight:bold;" />
                <Button text="Choisir"
                        prefWidth="120"
                        onAction="#chooseOption1"
                        style="-fx-background-color:#3b82f6;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:10;" />
            </VBox>

            <VBox alignment="CENTER" spacing="25"
                  prefWidth="180"
                  style="-fx-background-color:#f5f7ff;
                         -fx-background-radius:15;
                         -fx-padding:30;
                         -fx-border-color:#3b82f6;
                         -fx-border-radius:15;
                         -fx-border-width:2;">
                <Label fx:id="choice2Label"
                       wrapText="true"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       style="-fx-text-fill:#111; -fx-font-size:18px; -fx-font-weight:bold;" />
                <Button text="Choisir"
                        prefWidth="120"
                        onAction="#chooseOption2"
                        style="-fx-background-color:#3b82f6;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:10;" />
            </VBox>

            <VBox alignment="CENTER" spacing="25"
                  prefWidth="180"
                  style="-fx-background-color:#f5f7ff;
                         -fx-background-radius:15;
                         -fx-padding:30;
                         -fx-border-color:#3b82f6;
                         -fx-border-radius:15;
                         -fx-border-width:2;">
                <Label fx:id="choice3Label"
                       wrapText="true"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       style="-fx-text-fill:#111; -fx-font-size:18px; -fx-font-weight:bold;" />
                <Button text="Choisir"
                        prefWidth="120"
                        onAction="#chooseOption3"
                        style="-fx-background-color:#3b82f6;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:10;" />
            </VBox>
        </HBox>
    </VBox>
</StackPane>