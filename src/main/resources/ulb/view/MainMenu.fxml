<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" alignment="CENTER"
      spacing="20.0" fx:controller="ulb.view.MainMenu">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Bugemon" style="-fx-font-size: 42px;"/>
    <Button text="Create Team" onAction="#handleCreateTeam" prefWidth="200" prefHeight="50"/>
    <Button text="Exit" onAction="#handleExit" prefWidth="200" prefHeight="50"/>

</VBox>
