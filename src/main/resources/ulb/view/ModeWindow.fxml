<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane style="-fx-background-color: #ccccff;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.view.windows.ModeWindow">

   <VBox fx:id="content" alignment="CENTER" maxHeight="600" maxWidth="800" spacing="50">
      <Label text="BUGÉMON" style="-fx-font-size: 50; -fx-font-weight: bold;" />

      <HBox alignment="CENTER" spacing="80">
         <Button fx:id="SoloMode" onAction="#goSoloMode" prefHeight="100" prefWidth="200" style="-fx-background-color: #6699ff; -fx-border-color: black;" text="SOLO">
            <font>
               <Font size="20" />
            </font>
         </Button>

         <Button prefHeight="100" prefWidth="200" style="-fx-background-color: #ff9933; -fx-border-color: black;" text="MULTIPLAYER">
            <font>
               <Font size="20" />
            </font>
         </Button>
      </HBox>

      <Button fx:id="Quit" onAction="#quit" prefHeight="60" prefWidth="160" style="-fx-background-color: #800000; -fx-border-color: black;" text="QUITTER" textFill="white">
         <font>
            <Font size="16" />
         </font>
      </Button>
   </VBox>
</StackPane>
